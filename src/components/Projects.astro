<script>
    function initCarousel() {
        const viewport = document.getElementById("carouselViewport");
        const prevBtn = document.getElementById("carouselPrev");
        const nextBtn = document.getElementById("carouselNext");
        const dotsContainer = document.getElementById("carouselDots");
        if (!viewport) return;

        // Prevent double init on same elements
        if ((viewport as any).__carouselInit) return;
        (viewport as any).__carouselInit = true;

        const slides = Array.from(
            viewport.querySelectorAll<HTMLElement>(".carousel__slide"),
        );
        const dots = dotsContainer
            ? Array.from(
                  dotsContainer.querySelectorAll<HTMLElement>(".carousel__dot"),
              )
            : [];
        let currentIndex = 1; // Start on Featured Project (slide 1)
        let maxSlideHeight = 0; // Fixed height for all slides

        // Measure all slides once to find the tallest one
        function measureMaxHeight() {
            let maxH = 0;
            slides.forEach((slide) => {
                // Temporarily show each slide in flow to measure
                slide.style.position = "relative";
                slide.style.opacity = "1";
                slide.style.transform = "none";
                slide.style.pointerEvents = "auto";
                const h = slide.offsetHeight;
                if (h > maxH) maxH = h;
                slide.style.position = "";
                slide.style.opacity = "";
                slide.style.transform = "";
                slide.style.pointerEvents = "";
            });
            maxSlideHeight = Math.max(maxH, 300);
            if (viewport) {
                viewport.style.height = `${maxSlideHeight}px`;
            }
        }

        function updateSlides() {
            // Update state classes on each slide
            slides.forEach((slide, i) => {
                const diff = i - currentIndex;
                const newState =
                    diff === 0
                        ? "active"
                        : diff === -1
                          ? "prev"
                          : diff === 1
                            ? "next"
                            : diff < -1
                              ? "far-prev"
                              : "far-next";

                // Remove all state classes and add the correct one
                slide.classList.remove(
                    "carousel__slide--active",
                    "carousel__slide--init",
                    "carousel__slide--prev",
                    "carousel__slide--next",
                    "carousel__slide--far-prev",
                    "carousel__slide--far-next",
                );
                slide.classList.add(`carousel__slide--${newState}`);
            });

            // Keep viewport height steady using pre-measured max
            if (viewport && maxSlideHeight) {
                viewport.style.height = `${maxSlideHeight}px`;
            }

            // Update dots
            dots.forEach((dot, i) => {
                dot.classList.toggle(
                    "carousel__dot--active",
                    i === currentIndex,
                );
                dot.setAttribute("aria-selected", String(i === currentIndex));
            });

            // Update arrow visibility
            if (prevBtn) {
                prevBtn.classList.toggle(
                    "carousel__arrow--hidden",
                    currentIndex === 0,
                );
            }
            if (nextBtn) {
                nextBtn.classList.toggle(
                    "carousel__arrow--hidden",
                    currentIndex === slides.length - 1,
                );
            }
        }

        function goToSlide(index: number) {
            currentIndex = Math.max(0, Math.min(index, slides.length - 1));
            updateSlides();
        }

        // Click on side cards to navigate
        slides.forEach((slide: HTMLElement, i: number) => {
            slide.addEventListener("click", () => {
                if (i !== currentIndex) {
                    goToSlide(i);
                }
            });
        });

        // Arrow buttons
        prevBtn?.addEventListener("click", () => goToSlide(currentIndex - 1));
        nextBtn?.addEventListener("click", () => goToSlide(currentIndex + 1));

        // Dot navigation
        dots.forEach((dot: HTMLElement) => {
            dot.addEventListener("click", () => {
                const idx = parseInt(dot.dataset.index ?? "0", 10);
                goToSlide(idx);
            });
        });

        // Keyboard navigation
        viewport.setAttribute("tabindex", "0");
        viewport.addEventListener("keydown", (e) => {
            if (e.key === "ArrowLeft") {
                e.preventDefault();
                goToSlide(currentIndex - 1);
            } else if (e.key === "ArrowRight") {
                e.preventDefault();
                goToSlide(currentIndex + 1);
            }
        });

        // Drag/swipe
        let isDragging = false;
        let startX = 0;
        let hasMoved = false;

        viewport.addEventListener("pointerdown", (e: PointerEvent) => {
            const target = e.target as HTMLElement;
            if (target.closest("a") || target.closest("button")) return;
            isDragging = true;
            hasMoved = false;
            startX = e.clientX;
        });

        viewport.addEventListener("pointermove", (e) => {
            if (!isDragging) return;
            const walk = Math.abs(e.clientX - startX);
            if (walk > 10) hasMoved = true;
        });

        viewport.addEventListener("pointerup", (e) => {
            if (!isDragging) return;
            isDragging = false;
            if (!hasMoved) return;
            const dx = e.clientX - startX;
            if (dx > 50) {
                goToSlide(currentIndex - 1);
            } else if (dx < -50) {
                goToSlide(currentIndex + 1);
            }
        });

        viewport.addEventListener("pointerleave", () => {
            isDragging = false;
        });

        // First measure once, then apply slide states
        measureMaxHeight();
        updateSlides();

        // Re-measure after fonts and layout are fully resolved
        requestAnimationFrame(() => {
            measureMaxHeight();
        });
    }

    // Run immediately and on Astro page transitions
    initCarousel();
    document.addEventListener("astro:page-load", initCarousel);
</script>

