        left: 0;
        right: 0;
        width: 92%;
        max-width: 880px;
        margin-inline: auto;
        background: #0e0e0e;
        border: none;
        border-radius: 1rem;
        overflow: hidden;
        transition:
            transform 0.65s cubic-bezier(0.25, 0.1, 0.25, 1),
            opacity 0.5s ease;
        opacity: 0;
        cursor: pointer;
        z-index: 1;
        pointer-events: none;
    }
    /* Active slide visible before JS initializes */
    .carousel__slide--init {
        transform: translate(0, -50%);
        opacity: 1;
        z-index: 4;
        pointer-events: auto;
        cursor: default;
    }
    .carousel__slide--active {
        transform: translate(0, -50%);
        opacity: 1;
        z-index: 4;
        pointer-events: auto;
        cursor: default;
    }

    .carousel__slide--prev {
        transform: translate(calc(-55%), -50%);
        opacity: 0.4;
        z-index: 2;
        pointer-events: auto;
        cursor: pointer;
    }

    .carousel__slide--next {
        transform: translate(55%, -50%);
        opacity: 0.4;
        z-index: 2;
        pointer-events: auto;
        cursor: pointer;
    }

    .carousel__slide--far-prev {
        transform: translate(-110%, -50%);
        opacity: 0;
        z-index: 0;
        pointer-events: none;
    }

    .carousel__slide--far-next {
        transform: translate(110%, -50%);
        opacity: 0;
        z-index: 0;
        pointer-events: none;
    }

