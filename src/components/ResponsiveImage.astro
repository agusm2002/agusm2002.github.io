---
interface Props {
  src: string;
  alt: string;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "auto" | "sync";
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  class: className,
  loading = "lazy",
  decoding = "async",
  width,
  height,
} = Astro.props;

const v = "?v=20260422";
---

<picture>
  <source type="image/avif" srcset={`${src}.avif${v}`} />
  <source type="image/webp" srcset={`${src}.webp${v}`} />
  <img
    src={`${src}.png${v}`}
    alt={alt}
    class={className}
    loading={loading}
    decoding={decoding}
    width={width}
    height={height}
  />
</picture>
