const baseUrl = import.meta.env.BASE_URL;
const faviconHref = `${baseUrl}favicon.svg?v=2`;
const isEnglish = lang === "en";

const prefix = isEnglish ? "/en" : "";
const currentPath = Astro.url.pathname;

const groupIconSrc = [
    // Getting Started — no brand logo, clock/guide
    null,
    // Phase 1 — Rocky Linux
    "/tech-icons/rockylinux.svg",
    // Phase 2 — OpenTofu (IaC)
    "/tech-icons/opentofu.svg",
    // Phase 3 — HashiCorp Vault
    "/tech-icons/vault.svg",
    // Phase 4 — k3s
    "/tech-icons/k3s.svg",
    // Phase 5 — n8n
    "/tech-icons/n8n.svg",
    // Phase 6 — Jenkins
    "/tech-icons/jenkins.svg",
    // Phase 7 — ArgoCD
    "/tech-icons/argocd.svg",
    // Phase 8 — Security (no brand logo)
    null,
    // Phase 9 — Oracle Cloud
    "/tech-icons/oci.svg",
    // Phase 10 — Grafana
    "/tech-icons/grafana.svg",
    // Reference — no brand logo
    null,
];

// Fallback inline SVGs for groups without brand logos
const groupIconFallback = [
    `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    "",
    "",
    "",
    "",
    "",
    "",
    "",
    `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 12 15 16 10"/></svg>`,
    "",
    "",
    `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>`,
