        <script>
            function initSidebar() {
                const toggle = document.getElementById("sidebarToggle");
                const sidebar = document.getElementById("docsSidebar");
                const overlay = document.getElementById("sidebarOverlay");
                const collapseBtn =
                    document.getElementById("sidebarCollapse");
                const expandBtn = document.getElementById("sidebarExpand");
                const layout = document.querySelector(".docs-layout");

                // Mobile toggle
                function openSidebar() {
                    sidebar?.classList.add("docs-sidebar--open");
                    overlay?.classList.add("sidebar-overlay--visible");
                    document.body.style.overflow = "hidden";
                }
                function closeSidebar() {
                    sidebar?.classList.remove("docs-sidebar--open");
                    overlay?.classList.remove("sidebar-overlay--visible");
                    document.body.style.overflow = "";
                }
                toggle?.addEventListener("click", () => {
                    sidebar?.classList.contains("docs-sidebar--open")
                        ? closeSidebar()
                        : openSidebar();
                });
                overlay?.addEventListener("click", closeSidebar);

                // Desktop collapse
                collapseBtn?.addEventListener("click", () => {
                    layout?.classList.add("docs-layout--collapsed");
                    localStorage.setItem("docsSidebarCollapsed", "true");
                });
                expandBtn?.addEventListener("click", () => {
                    layout?.classList.remove("docs-layout--collapsed");
                    localStorage.setItem("docsSidebarCollapsed", "false");
                });
                if (
                    localStorage.getItem("docsSidebarCollapsed") === "true" &&
                    window.innerWidth > 900
                ) {
                    layout?.classList.add("docs-layout--collapsed");
                }

                // ── Collapsable groups ──
                sidebar?.querySelectorAll(".sidebar-group").forEach((group) => {
                    const label = group.querySelector(
                        ".sidebar-group__label",
                    );
                    const itemsContainer = group.querySelector(
                        ".sidebar-group__items",
                    );
                    if (!label || !itemsContainer) return;
                    // guard: skip if already initialised (transition:persist re-runs initSidebar)
                    if ((label as HTMLElement).dataset.groupInit) return;
                    (label as HTMLElement).dataset.groupInit = "1";

                    const isPreExpanded =
                        group.classList.contains("sidebar-group--expanded");
                    if (!isPreExpanded) {
                        itemsContainer.style.maxHeight = "0px";
                        group.classList.add("sidebar-group--collapsed");
                    }

                    label.addEventListener("click", () => {
                        const isCollapsed = group.classList.toggle(
                            "sidebar-group--collapsed",
                        );
                        if (!isCollapsed) {
                            itemsContainer.style.maxHeight =
                                itemsContainer.scrollHeight + "px";
                        } else {
                            itemsContainer.style.maxHeight =
                                itemsContainer.scrollHeight + "px";
                            requestAnimationFrame(() => {
                                itemsContainer.style.maxHeight = "0px";
                            });
                        }
                    });
                });

                // ── Table of Contents ──
                const toc = document.getElementById("docsToc");
                const tocNav = document.getElementById("docsTocNav");
                const main = document.querySelector(".docs-main");
                if (!toc || !tocNav || !main) return;

                // Clear previous TOC entries (important for view transitions)
                tocNav.innerHTML = "";

                const headings = main.querySelectorAll("h2");
                if (headings.length === 0) {
                    toc.style.display = "none";
                    return;
                }
                toc.style.display = "block";

                headings.forEach((h, i) => {
                    const id = h.id || `section-${i}`;
                    if (!h.id) h.id = id;
                    const a = document.createElement("a");
                    a.href = `#${id}`;
                    a.className = "docs-toc__link";
                    a.textContent = h.textContent;
                    a.addEventListener("click", (e) => {
                        e.preventDefault();
                        const rect = h.getBoundingClientRect();
                        const target = Math.max(
                            0,
                            window.scrollY +
                                rect.top -
                                window.innerHeight / 2 +
                                rect.height / 2,
                        );
                        window.scrollTo({
                            top: target,
                            behavior: "smooth",
                        });
                        history.pushState(null, "", `#${id}`);
                        setTimeout(updateActive, 260);
                    });
                    tocNav.appendChild(a);
                });

                const links = tocNav.querySelectorAll(".docs-toc__link");
                function throttle(fn, wait) {
                    let last = 0;
                    return (...args) => {
                        const now = Date.now();
                        if (now - last > wait) {
                            last = now;
                            fn(...args);
                        }
                    };
                }
                function updateActive() {
                    const offset = Math.max(
                        120,
                        window.innerHeight * 0.25,
                    );
                    if (
                        window.innerHeight + window.scrollY >=
                        document.body.scrollHeight - 4
                    ) {
                        links.forEach((l) =>
                            l.classList.remove("docs-toc__link--active"),
                        );
                        if (links[headings.length - 1])
                            links[headings.length - 1].classList.add(
                                "docs-toc__link--active",
                            );
                        return;
                    }
                    let closestIndex = 0;
                    let closestDist = Infinity;
                    for (let i = 0; i < headings.length; i++) {
                        const rect = headings[i].getBoundingClientRect();
                        const dist = Math.abs(rect.top - offset);
                        if (dist < closestDist) {
                            closestDist = dist;
                            closestIndex = i;
                        }
                    }
                    links.forEach((l) =>
                        l.classList.remove("docs-toc__link--active"),
                    );
                    if (links[closestIndex])
                        links[closestIndex].classList.add(
                            "docs-toc__link--active",
                        );
                }
                window.addEventListener(
                    "scroll",
                    throttle(updateActive, 100),
                );
                window.addEventListener("resize", updateActive);
                setTimeout(updateActive, 200);
            }

            // Called on initial load AND after each ClientRouter view transition
            document.addEventListener("astro:page-load", initSidebar);

            // Desktop collapse resize handler (guard against duplicate on ClientRouter re-run)
            if (!window.__sidebarResizeSet) {
                window.__sidebarResizeSet = true;
                window.addEventListener("resize", () => {
                    const layout =
                        document.querySelector(".docs-layout");
                    if (!layout) return;
                    if (window.innerWidth <= 900) {
                        layout.classList.remove("docs-layout--collapsed");
                    } else if (
                        localStorage.getItem("docsSidebarCollapsed") === "true"
                    ) {
                        layout.classList.add("docs-layout--collapsed");
                    }
                });
            }
        </script>

