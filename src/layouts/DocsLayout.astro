---
import ClientRouter from "astro/components/ClientRouter.astro";

interface Props {
    title?: string;
    description?: string;
    activePage?: string;
    lang?: "es" | "en";
    prev?: { label: string; href: string };
    next?: { label: string; href: string };
}
const {
    title = "ITOps Automation Lab Docs",
    description = "Documentación del ITOps Automation Lab",
    activePage = "",
    lang = "es",
