---
interface Props {
    title?: string;
    lang?: "es" | "en";
    description?: string;
}
const {
    title = "Agustín Monti - Portfolio",
    lang = "es",
    description = lang === "es"
        ? "Portfolio de Agustín Monti - Estudiante de Ingeniería en Informática apasionado por Linux, infraestructura y automatización."
        : "Portfolio of Agustín Monti - Computer Engineering student passionate about Linux, infrastructure, and automation.",
} = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const faviconHref = `${baseUrl}favicon.svg?v=2`;
---

<!doctype html>
<html lang={lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href={faviconHref} />
        <link rel="shortcut icon" type="image/svg+xml" href={faviconHref} />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="preload"
            as="style"
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
        />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap"
        />
    </head>
    <body>
        <!-- Background layers -->
        <div class="bg-blobs" aria-hidden="true">
            <div class="blob blob-1"></div>
            <div class="blob blob-2"></div>
            <div class="blob blob-3"></div>
        </div>
        <div class="bg-beams" aria-hidden="true">
            <div class="beam beam-1"></div>
            <div class="beam beam-2"></div>
            <div class="beam beam-3"></div>
            <div class="beam beam-4"></div>
            <div class="beam beam-5"></div>
            <div class="beam beam-6"></div>
            <div class="beam beam-7"></div>
            <div class="beam beam-8"></div>
            <div class="beam beam-9"></div>
            <div class="beam beam-10"></div>
            <div class="beam beam-11"></div>
            <div class="beam beam-12"></div>
            <div class="beam beam-13"></div>
            <div class="beam beam-14"></div>
        </div>
        <div class="bg-dots-base" aria-hidden="true"></div>
        <div class="bg-dots-sharp" aria-hidden="true"></div>

        <slot />
    </body>
</html>

<style is:global>
    /* ── CSS Houdini: metallic border angle ──────────── */
    @property --angle {
        syntax: "<angle>";
        inherits: false;
        initial-value: 160deg;
    }

    @keyframes light-shift {
        0% {
            --angle: 130deg;
        }
        33% {
            --angle: 185deg;
        }
        66% {
            --angle: 145deg;
        }
        100% {
            --angle: 130deg;
        }
    }

    /* ── Metallic border utility ────────────────────── */
    .metal-border {
        position: relative;
        --metal-delay: 0s;
        --metal-duration: 26s;
    }

    .metal-border::before {
        content: "";
        position: absolute;
        inset: 0;
        padding: 1.5px;
        border-radius: inherit;
        background: linear-gradient(
            var(--angle),
            #f5f5f5 0%,
            #aaa 20%,
            #333 48%,
            #999 75%,
            #efefef 100%
        );
        animation: light-shift var(--metal-duration) ease-in-out infinite;
        animation-delay: var(--metal-delay);
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
        z-index: 0;
    }

    /* ── Subtle metallic border (for inner pills, tags) ── */
    .metal-border-subtle {
        position: relative;
        --metal-delay: 0s;
        --metal-duration: 26s;
    }

    .metal-border-subtle::before {
        content: "";
        position: absolute;
        inset: 0;
        padding: 1px;
        border-radius: inherit;
        background: linear-gradient(
            var(--angle),
            rgba(180, 180, 180, 0.35) 0%,
            rgba(140, 140, 140, 0.2) 25%,
            rgba(80, 80, 80, 0.12) 50%,
            rgba(140, 140, 140, 0.2) 75%,
            rgba(180, 180, 180, 0.35) 100%
        );
        animation: light-shift var(--metal-duration) ease-in-out infinite;
        animation-delay: var(--metal-delay);
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
        z-index: 0;
    }

    /* ── Custom Properties ───────────────────────────── */
    :root {
        --bg: #0d0d0d;
        --surface: #111111;
        --surface-2: #161616;
        --green-50: #f5f5f5;
        --green-100: #e8e8e8;
        --green-300: #ccc;
        --green-400: #aaa;
        --green-500: #888;
        --green-600: #666;
        --green-700: #555;
        --green-900: #333;
        --text: #d4d4d4;
        --text-muted: #888;
        --text-dim: #555;
        --border: rgba(255, 255, 255, 0.07);
        --border-hover: rgba(255, 255, 255, 0.14);
        --font-display: "Space Grotesk", system-ui, sans-serif;
        --font-body: "Inter", system-ui, sans-serif;
        --font-mono: "JetBrains Mono", "Fira Code", monospace;
        /* ── Type Scale (Major Second, 1.125 ratio) ── */
        --text-2xs: 0.625rem; /* 10px – micro labels */
        --text-xs: 0.6875rem; /* 11px – tiny code/text */
        --text-sm: 0.75rem; /* 12px – labels, tags, mono */
        --text-base: 0.875rem; /* 14px – body UI, buttons */
        --text-md: 0.9375rem; /* 15px – prose, descriptions */
        --text-lg: 1rem; /* 16px – default */
        --text-xl: 1.125rem; /* 18px – subtitles */
        --text-2xl: 1.25rem; /* 20px – card titles */
        --text-3xl: 1.5rem; /* 24px – stats */
        --mouse-x: -500px;
        --mouse-y: -500px;
    }

    /* ── Reset ───────────────────────────────────────── */
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    html {
        overflow-x: hidden;
    }

    body {
        background-color: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
        font-size: 1rem;
        line-height: 1.6;
        overflow-x: hidden;
    }

    ::selection {
        background: rgba(255, 255, 255, 0.15);
        color: #fff;
    }

    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: var(--bg);
    }
    ::-webkit-scrollbar-thumb {
        background: #444;
        border-radius: 4px;
        border: 2px solid var(--bg);
    }

    h1,
    h2,
    h3,
    h4 {
        font-family: var(--font-display);
        line-height: 1.15;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    img,
    svg {
        display: block;
    }

    /* ── Background: subtle dot grid only ──────────── */
    .bg-blobs {
        display: none;
    }

    .bg-beams {
        display: none;
    }

    .bg-dots-base {
        position: fixed;
        inset: 0;
        background-image: radial-gradient(
            circle,
            rgba(255, 255, 255, 0.035) 1px,
            transparent 1px
        );
        background-size: 26px 26px;
        pointer-events: none;
        z-index: 0;
    }

    .bg-dots-sharp {
        position: fixed;
        inset: 0;
        background-image: radial-gradient(
            circle,
            rgba(255, 255, 255, 0.6) 1px,
            transparent 1px
        );
        background-size: 26px 26px;
        -webkit-mask-image: radial-gradient(
            circle 280px at var(--mouse-x) var(--mouse-y),
            black 0%,
            transparent 100%
        );
        mask-image: radial-gradient(
            circle 280px at var(--mouse-x) var(--mouse-y),
            black 0%,
            transparent 100%
        );
        pointer-events: none;
        z-index: 0;
        transition:
            -webkit-mask-position 0.05s,
            mask-position 0.05s;
    }

    /* ── Layout Utilities ────────────────────────────── */
    .container {
        width: 100%;
        max-width: 1100px;
        margin-inline: auto;
        padding-inline: 1.5rem;
    }

    .section {
        position: relative;
        z-index: 1;
        padding-block: 4.5rem;
    }

    section[id] {
        scroll-margin-top: 80px;
    }
    #about {
        scroll-margin-top: 60px;
    }
    #projects {
        scroll-margin-top: 110px;
    }

    main {
        position: relative;
        z-index: 1;
    }

    .divider {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 1px;
        background: linear-gradient(
            to right,
            transparent,
            rgba(255, 255, 255, 0.08),
            transparent
        );
    }

    /* ── Typography ──────────────────────────────────── */
    .section-label {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--green-400);
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .section-label::before {
        content: "";
        width: 1.5rem;
        height: 1px;
        background: var(--green-400);
        flex-shrink: 0;
    }

    .section-title {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        color: var(--green-50);
        font-weight: 700;
        letter-spacing: -0.02em;
    }

    /* ── Buttons ─────────────────────────────────────── */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-family: var(--font-display);
        font-size: var(--text-base);
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid transparent;
    }

    .btn-primary {
        background: #0e0e0e;
        color: var(--green-100);
        border: none;
    }

    .btn-primary:hover {
        background: #141414;
        transform: translateY(-1px);
    }

    .btn-outline {
        background: transparent;
        color: var(--green-300);
        border-color: var(--border-hover);
        overflow: hidden;
    }

    .btn-outline:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-1px);
    }

    /* ── 3D Tilt Cards ──────────────────────────────── */
    [data-tilt] {
        transition: transform 0.08s ease-out;
    }

    [data-tilt]::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: radial-gradient(
            circle at var(--tilt-x, 50%) var(--tilt-y, 50%),
            rgba(255, 255, 255, 0.07),
            transparent 55%
        );
        pointer-events: none;
        z-index: 2;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    [data-tilt]:hover::after {
        opacity: 1;
    }

    /* ── Reveal (GSAP animates these) ────────────────── */
    .reveal {
        opacity: 0;
        transform: translateY(28px);
    }

    /* ── Tech icons ──────────────────────────────────── */
    .tech-icon {
        display: block;
        width: 14px;
        height: 14px;
        flex-shrink: 0;
    }

    .tech-icon--fill {
        fill: currentColor;
    }

    .tech-icon--stroke {
        stroke: currentColor;
        fill: none;
    }
</style>

<script>
    import Lenis from "lenis";
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    /* ── Lenis + GSAP sync ── */
    const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });

    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add((time: number) => {
        lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);

    /* ── Interactive dot-grid spotlight ── */
    document.addEventListener("mousemove", (e: MouseEvent) => {
        document.documentElement.style.setProperty(
            "--mouse-x",
            e.clientX + "px",
        );
        document.documentElement.style.setProperty(
            "--mouse-y",
            e.clientY + "px",
        );
    });

    /* ── Scroll-triggered reveals ── */
    gsap.utils.toArray<HTMLElement>(".reveal").forEach((el) => {
        gsap.to(el, {
            scrollTrigger: {
                trigger: el,
                start: "top bottom",
                toggleActions: "play none none reset",
            },
            y: 0,
            opacity: 1,
            duration: 0.7,
            ease: "power3.out",
        });
    });

    /* ── Stagger reveal groups ── */
    document.querySelectorAll<HTMLElement>(".reveal-group").forEach((group) => {
        const items = group.querySelectorAll<HTMLElement>(".reveal-item");
        gsap.from(items, {
            scrollTrigger: {
                trigger: group,
                start: "top bottom",
                toggleActions: "play none none reset",
            },
            y: 22,
            opacity: 0,
            duration: 0.55,
            stagger: 0.07,
            ease: "power3.out",
        });
    });

    /* ── Nav links: delegate to Lenis to avoid double-click artefact ── */
    const NAV_OFFSETS: Record<string, number> = {
        about: -60,
        projects: -110,
    };
    document
        .querySelectorAll<HTMLAnchorElement>(".nav__link, .nav__logo")
        .forEach((link) => {
            link.addEventListener("click", (e) => {
                const href = link.getAttribute("href") ?? "";
                const hashIdx = href.indexOf("#");
                if (hashIdx === -1) return;
                const id = href.slice(hashIdx + 1);
                const target = document.getElementById(id);
                if (!target) return;
                e.preventDefault();
                lenis.scrollTo(target, { offset: NAV_OFFSETS[id] ?? -80 });
            });
        });

    /* ── Nav: hide on scroll down, show on scroll up ── */
    const nav = document.querySelector<HTMLElement>(".nav");
    let navHidden = false;
    lenis.on(
        "scroll",
        ({ scroll, direction }: { scroll: number; direction: number }) => {
            if (!nav) return;
            if (scroll < 80) {
                nav.classList.remove("nav--hidden");
                navHidden = false;
            } else if (direction > 0 && !navHidden) {
                nav.classList.add("nav--hidden");
                navHidden = true;
            } else if (direction < 0 && navHidden) {
                nav.classList.remove("nav--hidden");
                navHidden = false;
            }
        },
    );

    /* ── 3D Tilt effect for cards ────────────────────── */

    document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((card) => {
        const maxTilt = parseFloat(card.dataset.tiltMax ?? "7");
        let revealed = false;

        /* Don't start tilt until GSAP reveal finishes */
        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        revealed = true;
                        observer.disconnect();
                    }
                });
            },
            { threshold: 0.1 },
        );
        observer.observe(card);

        card.addEventListener("mousemove", (e) => {
            if (!revealed) return;
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;

            const rotateX = ((y - centerY) / centerY) * -maxTilt;
            const rotateY = ((x - centerX) / centerX) * maxTilt;

            card.style.transform = `perspective(1000px) rotateX(${rotateX.toFixed(2)}deg) rotateY(${rotateY.toFixed(2)}deg)`;
            card.style.setProperty(
                "--tilt-x",
                `${((x / rect.width) * 100).toFixed(1)}%`,
            );
            card.style.setProperty(
                "--tilt-y",
                `${((y / rect.height) * 100).toFixed(1)}%`,
            );
        });

        card.addEventListener("mouseleave", () => {
            card.style.transition = "transform 0.5s ease-out";
            card.style.transform =
                "perspective(1000px) rotateX(0deg) rotateY(0deg)";
            card.style.setProperty("--tilt-x", "50%");
            card.style.setProperty("--tilt-y", "50%");
            card.addEventListener("transitionend", function reset() {
                card.style.transition = "";
                card.removeEventListener("transitionend", reset);
            });
        });
    });
</script>
