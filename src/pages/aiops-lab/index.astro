<script>
    function setupToggle(btnId, contentId) {
        const btn = document.getElementById(btnId);
        const content = document.getElementById(contentId);
        if (btn && content) {
            btn.addEventListener('click', () => {
                const isCollapsed = content.classList.toggle('collapsed');
                btn.setAttribute('aria-expanded', !isCollapsed);
                btn.setAttribute('data-collapsed', isCollapsed);
                btn.querySelector('span').textContent = isCollapsed ? 'Mostrar' : 'Ocultar';
            });
        }
    }
    setupToggle('toggle-screenshots', 'screenshots-content');
    setupToggle('toggle-videos', 'videos-content');
</script>
