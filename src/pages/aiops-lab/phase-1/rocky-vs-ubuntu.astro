        color: var(--green-400);
    }

    .info-card__icon {
        flex-shrink: 0;
        color: var(--green-400);
        margin-top: 0.1rem;
    }

    .info-card__icon svg {
        width: 16px;
        height: 16px;
        display: block;
    }

    .info-card__text strong {
        color: var(--green-50);
