    }

    .market-card__share {
        font-family: var(--font-mono);
        font-size: var(--text-2xs);
        color: var(--text-dim);
    }

    .market-card__verticals {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
    }

    .market-card__verticals span {
        font-size: var(--text-2xs);
        color: var(--text-dim);
        padding: 0.15rem 0.4rem;
