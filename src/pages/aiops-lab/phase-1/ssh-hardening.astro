    }

    .f1-hero__time {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--text-dim);
        padding: 0.35rem 0.65rem;
        border-radius: 0.4rem;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.02);
    }

    .f1-hero__title {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 700;
        color: var(--green-50);
        line-height: 1.15;
        margin-bottom: 0.5rem;
    }

    .f1-hero__accent {
        color: var(--green-500);
        font-weight: 500;
    }

    .f1-hero__subtitle {
        font-size: var(--text-md);
        color: var(--text-muted);
        line-height: 1.6;
        max-width: 560px;
    }

    /* ── Sections ── */
    .overview-section {
        margin-bottom: 3rem;
    }

    .overview-section--cta {
        margin-top: 1rem;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.6rem;
    }

    .section-num {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--green-600);
        font-weight: 500;
    }

