---
import DocsLayout from "../../../layouts/DocsLayout.astro";

const differences = [
    { aspect: "Almacenamiento", dev: "En memoria. Al reiniciar el pod de Vault, todos los secrets, politicas y configuraciones se pierden.", prod: "Raft integrado (o Consul externo). Datos persistentes en PVC. Soporta snapshots y restore." },
    { aspect: "Unseal", dev: "Automatico. Vault arranca desellado y listo para usar. Cero interaccion manual.", prod: "Manual con Shamir Secret Sharing. 3 de 5 unseal keys necesarias. Se puede automatizar con Auto-Unseal via OCI KMS." },
    { aspect: "Root Token", dev: "Fijado en una variable de entorno del Deployment. Cualquiera con acceso al YAML lo conoce.", prod: "Generado una unica vez con vault operator init. Se almacena en un lugar seguro fuera del cluster. Nunca en un manifiesto." },
    { aspect: "TLS", dev: "Deshabilitado. La API de Vault escucha en HTTP plano (puerto 8200).", prod: "Obligatorio. Certificados TLS para la API, el cluster y el Vault Agent Injector. Sin TLS, Vault no arranca." },
    { aspect: "Audit Logging", dev: "Deshabilitado. No hay registro de quien accedio a que secret ni cuando.", prod: "Activado. Audit logs a file, socket o syslog. Cada acceso, creacion, modificacion y eliminacion de secrets queda registrado." },
    { aspect: "HA", dev: "Una sola replica. Si el pod muere, Vault deja de funcionar hasta que Kubernetes lo reinicie.", prod: "3 o 5 nodos con Raft consensus. Leader election automatica. El cluster sigue funcionando mientras la mayoria de nodos este viva." },
    { aspect: "Backup", dev: "No existe. Los datos estan en memoria y se pierden al reiniciar.", prod: "Snapshot via vault operator raft snapshot. Se puede automatizar con CronJob de Kubernetes. Backups a OCI Object Storage." },
    { aspect: "Storage Backend", dev: "inmem. No requiere configuracion. Util para desarrollo y testing.", prod: "Raft (recomendado) o Consul. Requiere PVC, configuracion de cluster y planificacion de capacidad." },
];

const prodConfig = [
    'storage "raft" {',
    '  path    = "/vault/data"',
    '  node_id = "vault-1"',
    "",
    '  retry_join {',
    '    leader_api_addr = "https://vault-0.vault-internal:8200"',
    "  }",
    "}",
    "",
    'listener "tcp" {',
    '  address       = "0.0.0.0:8200"',
    '  tls_cert_file = "/vault/tls/tls.crt"',
    '  tls_key_file  = "/vault/tls/tls.key"',
    "}",
    "",
    'api_addr     = "https://vault.aiops.svc.cluster.local:8200"',
    'cluster_addr = "https://vault.aiops.svc.cluster.local:8201"',
    "",
    "ui           = true",
    "disable_mlock = true",
].join("\n");
---

<DocsLayout
    title="Dev Mode vs Production - ITOps Automation Lab"
    description="Fase 3 del Rocky Linux ITOps Automation Lab: diferencias entre Vault en modo dev y produccion — almacenamiento, unseal, TLS, HA y camino de migracion."
    activePage="dev-vs-prod"
    prev={{
        label: "Flujo de Inyeccion de Secrets",
        href: "/aiops-lab/phase-3/secret-injection-flow",
    }}
    next={{
        label: "k3s Setup",
        href: "/aiops-lab/phase-4/k3s-setup",
    }}
>
    <div class="docs-page">
        <div class="f3-hero">
            <div class="f3-hero__top">
                <div class="f3-hero__badge">Fase 3.4</div>
                <span class="f3-hero__time">Dev vs Production</span>
            </div>
            <h1 class="f3-hero__title">Dev Mode vs Production<span class="f3-hero__accent"> · Que Cambia</span></h1>
            <p class="f3-hero__subtitle">
                La configuracion de Vault para el lab (modo dev) es radicalmente
                distinta a la que se usaria en produccion. Esta pagina documenta
                exactamente que cambia en cada aspecto y muestra la configuracion
                HCL que reemplazaria al flag -dev.
            </p>
        </div>

        <!-- Diff table -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">01</span><h2 class="overview-h2">Ocho Diferencias</h2></div>
            <p class="overview-lead">
                Cada aspecto de Vault cambia entre el modo dev y la produccion.
                Ninguna de estas diferencias es cosmética — cada una tiene
                implicaciones de seguridad, disponibilidad y operabilidad.
            </p>

            <div class="diff-list">
                {differences.map((d) => (
                    <div class="diff-card">
                        <div class="diff-card__aspect">{d.aspect}</div>
                        <div class="diff-card__cols">
                            <div class="diff-col diff-col--dev">
                                <div class="diff-col__label">Modo Dev</div>
                                <div class="diff-col__text">{d.dev}</div>
                            </div>
                            <div class="diff-col diff-col--prod">
                                <div class="diff-col__label">Produccion</div>
                                <div class="diff-col__text">{d.prod}</div>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Config -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">02</span><h2 class="overview-h2">Configuracion de Produccion</h2></div>
            <p class="overview-lead">
                En modo dev, Vault arranca con <code>vault server -dev</code> y
                toda la configuracion es implicita. En produccion, se usa un
                archivo HCL que define storage, listeners, TLS y clustering.
                El ConfigMap en <code>k3s/manifests/vault/configmap.yml</code>
                contiene la referencia para esta transicion.
            </p>

            <div class="code-block">
                <div class="code-block__header"><span class="code-block__file">vault.hcl (produccion)</span></div>
                <pre><code>{prodConfig}</code></pre>
            </div>

            <p class="overview-text">
                Este archivo se montaria como ConfigMap en el Deployment de
                Vault. El comando del contenedor cambiaria de <code>vault server
                -dev</code> a <code>vault server -config=/vault/config/vault.hcl</code>.
                El resto del Deployment —Service, ServiceAccount, readiness
                probe— permanece igual.
            </p>
        </div>

        <!-- Migration path -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">03</span><h2 class="overview-h2">Camino de Migracion</h2></div>
            <p class="overview-lead">
                Migrar de modo dev a produccion no es un toggle. Requiere
                planificacion, nuevos recursos de Kubernetes y un proceso de
                inicializacion manual. Estos son los pasos.
            </p>

            <div class="migrate-steps">
                <div class="ms-card">
                    <div class="ms-card__num">1</div>
                    <div class="ms-card__text">Agregar un PVC (PersistentVolumeClaim) para el storage Raft. En k3s, el local-path provisioner maneja esto automaticamente.</div>
                </div>
                <div class="ms-card">
                    <div class="ms-card__num">2</div>
                    <div class="ms-card__text">Montar el ConfigMap con vault.hcl en el Deployment. Reemplazar el flag -dev por -config=/vault/config/vault.hcl.</div>
                </div>
                <div class="ms-card">
                    <div class="ms-card__num">3</div>
                    <div class="ms-card__text">Generar certificados TLS para la API y el cluster. Se pueden crear con cert-manager o manualmente con openssl.</div>
                </div>
                <div class="ms-card">
                    <div class="ms-card__num">4</div>
                    <div class="ms-card__text">Ejecutar vault operator init. Guardar las 5 unseal keys y el root token en un lugar seguro fuera del cluster.</div>
                </div>
                <div class="ms-card">
                    <div class="ms-card__num">5</div>
                    <div class="ms-card__text">Unseal manual (o configurar Auto-Unseal via OCI KMS en Oracle Cloud).</div>
                </div>
                <div class="ms-card">
                    <div class="ms-card__num">6</div>
                    <div class="ms-card__text">Reconfigurar el Injector para usar TLS. Actualizar los webhooks y la configuracion de Kubernetes Auth.</div>
                </div>
            </div>

            <div class="info-card">
                <div class="info-card__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div class="info-card__text">
                    <strong>En el lab esto no se aplica.</strong> La migracion a
                    produccion de Vault se documenta como referencia. En Oracle
                    Cloud (Fase 9), Vault self-hosted se reemplaza directamente
                    por OCI Vault — el servicio gestionado. La decision de
                    arquitectura es: lab local = Vault self-hosted (modo dev),
                    Oracle Cloud = OCI Vault (gestionado). Dos modos de
                    operacion, un solo proyecto.
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="overview-section overview-section--cta">
            <div class="cta-card">
                <div class="cta-card__content">
                    <h3 class="cta-card__title">Fase 3 Completada</h3>
                    <p class="cta-card__desc">
                        Con Vault configurado y el flujo de inyeccion dominado,
                        la Fase 4 introduce el observability stack: k3s,
                        Prometheus, Loki, Grafana Alloy y dashboards de Grafana.
                    </p>
                </div>
                <a href="/aiops-lab/phase-4/k3s-setup" class="cta-card__btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg>
                    Fase 4 · k3s Setup
                </a>
            </div>
        </div>
    </div>
</DocsLayout>

<style is:global>
    .docs-page { max-width: 740px; }
    .f3-hero { background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.875rem; padding: 1.75rem; margin-bottom: 3rem; }
    .f3-hero__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
    .f3-hero__badge { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-300); padding: 0.35rem 0.7rem; border-radius: 0.4rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border); }
    .f3-hero__time { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-dim); padding: 0.35rem 0.65rem; border-radius: 0.4rem; border: 1px solid var(--border); background: rgba(255,255,255,0.02); }
    .f3-hero__title { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--green-50); line-height: 1.15; margin-bottom: 0.5rem; }
    .f3-hero__accent { color: var(--green-500); font-weight: 500; }
    .f3-hero__subtitle { font-size: var(--text-md); color: var(--text-muted); line-height: 1.6; max-width: 560px; }
    .overview-section { margin-bottom: 3rem; }
    .overview-section--cta { margin-top: 1rem; }
    .section-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .section-num { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-600); font-weight: 500; }
    .overview-h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; color: var(--green-50); margin: 0; }
    .overview-lead { font-size: var(--text-base); color: var(--text-muted); line-height: 1.65; margin-bottom: 1.5rem; max-width: 560px; }
    .overview-text { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.65; margin-bottom: 1rem; }
    .overview-text code { font-family: var(--font-mono); font-size: var(--text-xs); background: rgba(255,255,255,0.06); padding: 0.1rem 0.35rem; border-radius: 0.25rem; color: var(--green-300); }

    .diff-list { display: flex; flex-direction: column; gap: 0.4rem; }
    .diff-card { background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.6rem; padding: 0.75rem 0.9rem; }
    .diff-card__aspect { font-family: var(--font-mono); font-size: var(--text-2xs); color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.35rem; }
    .diff-card__cols { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
    .diff-col__label { font-family: var(--font-mono); font-size: var(--text-3xs); color: var(--green-500); margin-bottom: 0.15rem; display: block; }
    .diff-col--prod .diff-col__label { color: #3b82f6; }
    .diff-col__text { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.5; }

    .info-card { display: flex; gap: 0.65rem; padding: 0.875rem 1rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 0.6rem; font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; }
    .info-card__icon { flex-shrink: 0; color: var(--green-400); margin-top: 0.1rem; }
    .info-card__icon svg { width: 16px; height: 16px; display: block; }
    .info-card__text strong { color: var(--green-50); font-weight: 600; }

    .code-block { background: #0a0a0a; border: 1px solid var(--border); border-radius: 0.6rem; overflow: hidden; margin-bottom: 1rem; }
    .code-block__header { display: flex; align-items: center; padding: 0.45rem 0.85rem; background: rgba(255,255,255,0.025); border-bottom: 1px solid var(--border); }
    .code-block__file { font-family: var(--font-mono); font-size: var(--text-2xs); color: var(--text-dim); }
    .code-block pre { margin: 0; padding: 0.85rem; overflow-x: auto; }
    .code-block code { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); line-height: 1.55; }

    .migrate-steps { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1rem; }
    .ms-card { display: flex; gap: 0.65rem; padding: 0.55rem 0.8rem; background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.5rem; font-size: var(--text-sm); color: var(--text-muted); line-height: 1.5; }
    .ms-card__num { display: flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.5rem; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid var(--border); font-family: var(--font-mono); font-size: var(--text-2xs); font-weight: 600; color: var(--green-400); flex-shrink: 0; }

    .cta-card { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.25rem 1.5rem; background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.75rem; }
    .cta-card__content { flex: 1; }
    .cta-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--green-50); margin: 0 0 0.25rem; }
    .cta-card__desc { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.55; margin: 0; }
    .cta-card__btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; color: var(--green-50); background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 0.5rem; padding: 0.6rem 1rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: background 0.2s, border-color 0.2s; }
    .cta-card__btn:hover { background: rgba(255,255,255,0.08); border-color: var(--border-hover); }
    @media (max-width: 700px) { .diff-card__cols { grid-template-columns: 1fr; } }
    @media (max-width: 600px) { .cta-card { flex-direction: column; align-items: flex-start; } }
</style>
