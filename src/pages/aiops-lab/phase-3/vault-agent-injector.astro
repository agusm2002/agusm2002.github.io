---
import DocsLayout from "../../../layouts/DocsLayout.astro";

const templateExample = [
    "  annotations:",
    '    vault.hashicorp.com/agent-inject: "true"',
    '    vault.hashicorp.com/agent-inject-secret-admin: "secret/data/grafana"',
    '    vault.hashicorp.com/role: "grafana"',
    '    vault.hashicorp.com/agent-inject-template-admin: |',
    '      {{- with secret "secret/data/grafana" -}}',
    "      GF_SECURITY_ADMIN_USER={{ .Data.data.admin_user }}",
    "      GF_SECURITY_ADMIN_PASSWORD={{ .Data.data.admin_password }}",
    "      {{- end }}",
].join("\n");

const annotations = [
    { key: "vault.hashicorp.com/agent-inject", value: "true", required: true, desc: "Activa la inyeccion del Vault Agent en este pod. Sin esta annotation, el Injector ignora el pod completamente." },
    { key: "vault.hashicorp.com/agent-inject-secret-[name]", value: "secret/data/...", required: true, desc: "Define un secret a inyectar. El nombre despues de 'secret-' es el archivo donde se escribe. Ej: agent-inject-secret-db escribe en /vault/secrets/db." },
    { key: "vault.hashicorp.com/role", value: "[role-name]", required: true, desc: "Rol de Vault que asigna politicas al ServiceAccount del pod. Define que secrets puede leer este pod." },
    { key: "vault.hashicorp.com/agent-inject-template-[name]", value: "[template]", required: false, desc: "Template Go para formatear el secret. Util cuando se necesita un formato especifico (JSON, YAML, env file) en lugar del valor crudo." },
    { key: "vault.hashicorp.com/auth-path", value: "auth/kubernetes", required: false, desc: "Path del metodo de autenticacion Kubernetes en Vault. Default: auth/kubernetes." },
];

const injectorComponents = [
    { name: "ServiceAccount", role: "Identidad del Injector ante Kubernetes. Necesita permisos para leer pods y mutation webhooks.", file: "serviceaccount.yml" },
    { name: "ClusterRole", role: "Define permisos RBAC: get/list/watch sobre pods y mutation webhooks. Sin esto, el Injector no puede interceptar la creacion de pods.", file: "clusterrole.yml" },
    { name: "ClusterRoleBinding", role: "Vincula el ServiceAccount con el ClusterRole. Es la autorizacion que permite al Injector actuar.", file: "clusterrolebinding.yml" },
    { name: "Deployment", role: "El Injector en si: un pod escuchando en el puerto 8080. Expone /mutate que el API Server llama cuando se crea un pod con annotations de Vault.", file: "injector-deployment.yml" },
    { name: "Service", role: "Service ClusterIP que expone el Injector dentro del cluster. El API Server necesita alcanzarlo para enviar AdmissionReview requests.", file: "service.yml" },
    { name: "MutatingWebhookConfiguration", role: "Registra el webhook ante el API Server. Define que pods se interceptan y a que URL se envian.", file: "mutatingwebhook.yml" },
];
---

<DocsLayout
    title="Vault Agent Injector - ITOps Automation Lab"
    description="Fase 3 del Rocky Linux ITOps Automation Lab: Vault Agent Injector — Mutating Admission Webhook que inyecta automaticamente secrets de Vault en pods via annotations."
    activePage="vault-agent-injector"
    prev={{
        label: "HashiCorp Vault Overview",
        href: "/aiops-lab/phase-3/vault-overview",
    }}
    next={{
        label: "Kubernetes Auth Method",
        href: "/aiops-lab/phase-3/kubernetes-auth",
    }}
>
    <div class="docs-page">
        <div class="f3-hero">
            <div class="f3-hero__top">
                <div class="f3-hero__badge">Fase 3.1</div>
                <span class="f3-hero__time">Vault Agent Injector</span>
            </div>
            <h1 class="f3-hero__title">Vault Agent Injector<span class="f3-hero__accent"> · Admission Webhook</span></h1>
            <p class="f3-hero__subtitle">
                El corazon de la integracion Vault-Kubernetes. Un Mutating
                Admission Webhook que intercepta la creacion de pods, detecta
                annotations de Vault y modifica el pod spec para inyectar un
                init container que recupera secrets antes de que la app arranque.
            </p>
        </div>

        <!-- What -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">01</span><h2 class="overview-h2">Que Es y Como Funciona</h2></div>
            <p class="overview-lead">
                El Vault Agent Injector es un Mutating Admission Webhook de
                Kubernetes. Cuando el API Server recibe una solicitud de
                creacion de pod, antes de persistirla, envia el pod spec al
                Injector. Si el pod tiene annotations de Vault, el Injector
                modifica el spec agregando un init container. Si no, lo deja
                pasar sin cambios.
            </p>
            <div class="info-card">
                <div class="info-card__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div class="info-card__text">
                    <strong>El Injector no tiene acceso a los secrets.</strong>
                    Solo modifica el pod spec para agregar el init container.
                    Es el Vault Agent (init container) quien se autentica con
                    Vault usando el ServiceAccount token del pod y recupera los
                    secrets. El Injector orquesta, no accede.
                </div>
            </div>
        </div>

        <!-- Annotations -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">02</span><h2 class="overview-h2">Las Annotations</h2></div>
            <p class="overview-lead">
                Cinco annotations controlan el comportamiento del Injector.
                Tres son obligatorias: sin ellas, el Injector no interviene.
            </p>
            <div class="ann-list">
                {annotations.map((a) => (
                    <div class="ann-card">
                        <div class="ann-card__header">
                            <code class="ann-card__key">{a.key}</code>
                            <code class="ann-card__val">{a.value}</code>
                            {a.required
                                ? <span class="ann-tag ann-tag--req">obligatorio</span>
                                : <span class="ann-tag ann-tag--opt">opcional</span>
                            }
                        </div>
                        <div class="ann-card__desc">{a.desc}</div>
                    </div>
                ))}
            </div>

            <div class="code-block">
                <div class="code-block__header"><span class="code-block__file">Ejemplo: Deployment con annotations de Vault + Go template</span></div>
                <pre><code>{templateExample}</code></pre>
            </div>
        </div>

        <!-- Components -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">03</span><h2 class="overview-h2">Componentes del Injector</h2></div>
            <p class="overview-lead">
                Seis recursos de Kubernetes forman el Injector. Cada uno tiene
                una responsabilidad especifica.
            </p>
            <div class="comp-list">
                {injectorComponents.map((c) => (
                    <div class="comp-row">
                        <div class="comp-row__name">{c.name}</div>
                        <div class="comp-row__role">{c.role}</div>
                        <code class="comp-row__file">{c.file}</code>
                    </div>
                ))}
            </div>
        </div>

        <!-- What's injected -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">04</span><h2 class="overview-h2">Que Inyecta el Webhook</h2></div>
            <p class="overview-lead">
                Cuando el Injector detecta annotations de Vault, modifica el
                pod spec agregando tres elementos.
            </p>
            <div class="inject-grid">
                <div class="inject-card">
                    <div class="inject-card__label">1. Volumen compartido</div>
                    <code class="inject-card__code">emptyDir: vault-secrets</code>
                    <div class="inject-card__desc">Mount point /vault/secrets/ compartido entre el init container y el contenedor principal. Vive mientras el pod existe.</div>
                </div>
                <div class="inject-card">
                    <div class="inject-card__label">2. Init container</div>
                    <code class="inject-card__code">vault-agent-init</code>
                    <div class="inject-card__desc">Se autentica con Vault usando el ServiceAccount token. Recupera los secrets declarados en las annotations. Los escribe como archivos en /vault/secrets/.</div>
                </div>
                <div class="inject-card">
                    <div class="inject-card__label">3. Sidecar (opcional)</div>
                    <code class="inject-card__code">vault-agent</code>
                    <div class="inject-card__desc">Renueva el token de Vault periodicamente. Actualiza los secrets si cambiaron en Vault. Util para pods long-running que no pueden reiniciarse.</div>
                </div>
            </div>
            <div class="info-card info-card--tip">
                <div class="info-card__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </div>
                <div class="info-card__text">
                    <strong>Init container vs sidecar.</strong> El init container
                    se ejecuta una vez y termina. El sidecar corre toda la vida
                    del pod. Para secrets estaticos (no rotan), el init
                    container es suficiente. Para secrets dinamicos (rotacion
                    automatica), se necesita el sidecar.
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="overview-section overview-section--cta">
            <div class="cta-card">
                <div class="cta-card__content">
                    <h3 class="cta-card__title">Siguiente: Kubernetes Auth</h3>
                    <p class="cta-card__desc">
                        El Injector necesita que Vault confie en los
                        ServiceAccounts de Kubernetes. La pagina siguiente
                        explica como se configura el metodo de autenticacion
                        Kubernetes en Vault.
                    </p>
                </div>
                <a href="/aiops-lab/phase-3/kubernetes-auth" class="cta-card__btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg>
                    Kubernetes Auth
                </a>
            </div>
        </div>
    </div>
</DocsLayout>

<style is:global>
