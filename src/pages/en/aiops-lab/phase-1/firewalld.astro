        border-radius: 0.875rem;
        padding: 1.75rem;
        margin-bottom: 3rem;
    }

    .f1-hero__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .f1-hero__badge {
        display: inline-flex;
