        margin-bottom: 0.4rem;
    }
    .dim-row__cols { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem; }
    .dim-col__label {
        font-family: var(--font-mono);
        font-size: var(--text-3xs);
        color: var(--green-500);
        display: block;
        margin-bottom: 0.2rem;
    }
    .dim-col__text { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.55; margin-bottom: 0.35rem; display: block; }
    .dim-col__tag {
        font-family: var(--font-mono);
        font-size: var(--text-4xs);
        color: var(--text-dim);
        padding: 0.1rem 0.3rem;
        border-radius: 0.2rem;
