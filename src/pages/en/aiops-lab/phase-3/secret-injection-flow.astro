---
import DocsLayout from "../../../../layouts/DocsLayout.astro";

const steps = [
    { step: "1", title: "Developer aplica el Deployment", detail: "kubectl apply -f deployment.yml. El pod spec incluye annotations de Vault: agent-inject, agent-inject-secret-*, role." },
    { step: "2", title: "API Server recibe la solicitud", detail: "Antes de persistir el pod en etcd, el API Server envia un AdmissionReview al MutatingWebhook registrado por el Injector." },
    { step: "3", title: "Injector inspecciona el pod", detail: "Busca annotations vault.hashicorp.com/agent-inject. Si no existen, responde sin cambios. Si existen, procede a modificar el spec." },
    { step: "4", title: "Injector modifica el pod spec", detail: "Agrega un volumen emptyDir (vault-secrets), un init container (vault-agent-init) y opcionalmente un sidecar (vault-agent). El contenedor principal original no se modifica." },
    { step: "5", title: "API Server crea el pod modificado", detail: "El pod que llega a etcd ya tiene el init container inyectado. El developer nunca ve esta modificacion en su YAML original." },
    { step: "6", title: "Init container arranca", detail: "vault-agent-init se ejecuta antes que el contenedor principal. Se autentica con Vault usando el ServiceAccount token. Recupera los secrets declarados en las annotations." },
    { step: "7", title: "Secrets se escriben en disco", detail: "El init container escribe cada secret como un archivo en /vault/secrets/. El formato depende de si se uso agent-inject-template o no." },
    { step: "8", title: "Init container termina", detail: "El init container sale con codigo 0. El volumen emptyDir con los secrets persiste." },
    { step: "9", title: "Contenedor principal arranca", detail: "La aplicacion lee los secrets desde /vault/secrets/. No necesita saber que Vault existe — solo lee archivos." },
];

const timeline = [
    { time: "t=0s", event: "kubectl apply enviado", detail: "El Deployment YAML llega al API Server." },
    { time: "t=0.1s", event: "Admission webhook triggered", detail: "API Server llama al Injector en /mutate." },
    { time: "t=0.2s", event: "Pod spec modificado", detail: "Injector agrega init container + volumen al spec." },
    { time: "t=0.3s", event: "Pod creado en etcd", detail: "El pod se persiste con las modificaciones del Injector." },
    { time: "t=2s", event: "Init container inicia", detail: "vault-agent-init arranca. Se autentica con Vault." },
    { time: "t=3s", event: "Secrets recuperados", detail: "Vault devuelve los secrets. El init container los escribe en /vault/secrets/." },
    { time: "t=4s", event: "App container arranca", detail: "El contenedor principal inicia. Los secrets ya estan en disco." },
];
---

<DocsLayout
    title="Flujo de Inyeccion de Secrets - ITOps Automation Lab"
    description="Phase 3 del Rocky Linux ITOps Automation Lab: flujo completo de inyeccion de secrets — desde kubectl apply hasta el secret en el filesystem del contenedor."
    activePage="secret-injection-flow"
    lang="en"
    prev={{
        label: "Kubernetes Auth Method",
        href: "/en/aiops-lab/phase-3/kubernetes-auth",
    }}
    next={{
        label: "Dev Mode vs Production",
        href: "/en/aiops-lab/phase-3/dev-vs-prod",
    }}
>
    <div class="docs-page">
        <div class="f3-hero">
            <div class="f3-hero__top">
                <div class="f3-hero__badge">Phase 3.3</div>
                <span class="f3-hero__time">Injection Flow</span>
            </div>
            <h1 class="f3-hero__title">Flujo de Inyeccion<span class="f3-hero__accent"> · End-to-End</span></h1>
            <p class="f3-hero__subtitle">
                Nueve pasos desde que el developer hace kubectl apply hasta
                que el contenedor lee el secret del filesystem. Entender este
                flujo es entender como funciona la integracion Vault-Kubernetes.
            </p>
        </div>

        <!-- Steps -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">01</span><h2 class="overview-h2">Los Nueve Pasos</h2></div>
            <p class="overview-lead">
                Cada paso es una pieza del mecanismo de inyeccion. El
                developer solo ve el paso 1 (el YAML que escribe) y el paso 9
                (los secrets en el filesystem). Los pasos 2-8 son
                responsabilidad de Kubernetes, el Injector y Vault.
            </p>

            <div class="steps-vert">
                {steps.map((s) => (
                    <div class="sv-item">
                        <div class="sv-item__num">{s.step}</div>
                        <div class="sv-item__content">
                            <div class="sv-item__title">{s.title}</div>
                            <div class="sv-item__detail">{s.detail}</div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Timeline -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">02</span><h2 class="overview-h2">Timeline</h2></div>
            <p class="overview-lead">
                En un cluster local con k3s, el proceso completo desde
                kubectl apply hasta que la app arranca con secrets tarda
                aproximadamente 4 segundos.
            </p>

            <div class="tl-list">
                {timeline.map((t, i) => (
                    <div class="tl-row">
                        <div class="tl-row__time">{t.time}</div>
                        <div class="tl-row__dot"></div>
                        <div class="tl-row__content">
                            <div class="tl-row__event">{t.event}</div>
                            <div class="tl-row__detail">{t.detail}</div>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <!-- Filesystem -->
        <div class="overview-section">
            <div class="section-header"><span class="section-num">03</span><h2 class="overview-h2">Resultado en el Filesystem</h2></div>
            <p class="overview-lead">
                El resultado final de todo el flujo: archivos en
                /vault/secrets/ que la aplicacion lee como cualquier otro
                archivo de configuracion.
            </p>

            <div class="terminal-block">
                <div class="terminal-block__bar">
                    <div class="terminal-block__dots"><span></span><span></span><span></span></div>
                    <span class="terminal-block__title">dentro del contenedor</span>
                </div>
                <div class="terminal-block__body">
                    <div class="t-line"><span class="t-prompt">$</span><span class="t-cmd">ls -la /vault/secrets/</span></div>
                    <div class="t-line"><span class="t-out">-rw-r--r-- 1 vault vault  64 May 31 10:00 admin</span></div>
                    <div class="t-line"><span class="t-out">-rw-r--r-- 1 vault vault 128 May 31 10:00 db</span></div>
                    <div class="t-line t-line--spacer"></div>
                    <div class="t-line"><span class="t-comment"># Contenido del secret grafana admin</span></div>
                    <div class="t-line"><span class="t-prompt">$</span><span class="t-cmd">cat /vault/secrets/admin</span></div>
                    <div class="t-line"><span class="t-out">GF_SECURITY_ADMIN_USER=admin</span></div>
                    <div class="t-line"><span class="t-out">GF_SECURITY_ADMIN_PASSWORD=s3cur3-p4ss</span></div>
                    <div class="t-line t-line--spacer"></div>
                    <div class="t-line"><span class="t-comment"># El contenedor fuente estas variables en su entrypoint</span></div>
                    <div class="t-line"><span class="t-prompt">$</span><span class="t-cmd">source /vault/secrets/admin && ./start.sh</span></div>
                </div>
            </div>

            <div class="info-card info-card--tip">
                <div class="info-card__icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                </div>
                <div class="info-card__text">
                    <strong>El contenedor no sabe que Vault existe.</strong>
                    Desde la perspectiva de la aplicacion, los secrets son
                    archivos en /vault/secrets/. No hay llamadas HTTP a Vault,
                    no hay SDKs, no hay logica de autenticacion. El Injector y
                    el init container abstraen todo eso. Si se migra de Vault a
                    OCI Vault o a AWS Secrets Manager, la aplicacion no cambia
                    — solo cambia el mecanismo de inyeccion.
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="overview-section overview-section--cta">
            <div class="cta-card">
                <div class="cta-card__content">
                    <h3 class="cta-card__title">Siguiente: Dev Mode vs Production</h3>
                    <p class="cta-card__desc">
                        El flujo de inyeccion funciona igual en modo dev y en
                        produccion. La ultima pagina de la Phase 3 detalla que
                        cambia entre ambos modos y como es la transicion a un
                        Vault production-ready.
                    </p>
                </div>
                <a href="/en/aiops-lab/phase-3/dev-vs-prod" class="cta-card__btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg>
                    Dev vs Prod
                </a>
            </div>
        </div>
    </div>
</DocsLayout>

<style is:global>
    .docs-page { max-width: 740px; }
    .f3-hero { background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.875rem; padding: 1.75rem; margin-bottom: 3rem; }
    .f3-hero__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
    .f3-hero__badge { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-300); padding: 0.35rem 0.7rem; border-radius: 0.4rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border); }
    .f3-hero__time { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-dim); padding: 0.35rem 0.65rem; border-radius: 0.4rem; border: 1px solid var(--border); background: rgba(255,255,255,0.02); }
    .f3-hero__title { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--green-50); line-height: 1.15; margin-bottom: 0.5rem; }
    .f3-hero__accent { color: var(--green-500); font-weight: 500; }
    .f3-hero__subtitle { font-size: var(--text-md); color: var(--text-muted); line-height: 1.6; max-width: 560px; }
    .overview-section { margin-bottom: 3rem; }
    .overview-section--cta { margin-top: 1rem; }
    .section-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .section-num { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-600); font-weight: 500; }
    .overview-h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; color: var(--green-50); margin: 0; }
    .overview-lead { font-size: var(--text-base); color: var(--text-muted); line-height: 1.65; margin-bottom: 1.5rem; max-width: 560px; }

    .info-card { display: flex; gap: 0.65rem; padding: 0.875rem 1rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 0.6rem; font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; }
    .info-card--tip { border-color: rgba(34,197,94,0.2); background: rgba(34,197,94,0.03); }
    .info-card--tip .info-card__icon { color: var(--green-400); }
    .info-card__icon { flex-shrink: 0; color: var(--green-400); margin-top: 0.1rem; }
    .info-card__icon svg { width: 16px; height: 16px; display: block; }
    .info-card__text strong { color: var(--green-50); font-weight: 600; }
    .info-card__text code { font-family: var(--font-mono); font-size: var(--text-xs); background: rgba(255,255,255,0.06); padding: 0.1rem 0.35rem; border-radius: 0.25rem; color: var(--green-300); }

    .steps-vert { display: flex; flex-direction: column; gap: 0.35rem; }
    .sv-item { display: flex; gap: 0.65rem; padding: 0.55rem 0.8rem; background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.5rem; }
    .sv-item__num { display: flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.5rem; border-radius: 50%; background: rgba(255,255,255,0.05); border: 1px solid var(--border); font-family: var(--font-mono); font-size: var(--text-2xs); font-weight: 600; color: var(--green-400); flex-shrink: 0; }
    .sv-item__title { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: 600; color: var(--green-300); margin-bottom: 0.1rem; }
    .sv-item__detail { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.5; }

    .tl-list { position: relative; padding-left: 2rem; }
    .tl-row { display: flex; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.5rem; position: relative; }
    .tl-row__time { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-400); min-width: 50px; flex-shrink: 0; padding-top: 0.1rem; }
    .tl-row__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green-500); flex-shrink: 0; margin-top: 0.35rem; position: relative; z-index: 1; }
    .tl-row__content { flex: 1; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
    .tl-row__event { font-size: var(--text-sm); font-weight: 600; color: var(--green-50); margin-bottom: 0.1rem; }
    .tl-row__detail { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.45; }

    .terminal-block { background: #0a0a0a; border: 1px solid var(--border); border-radius: 0.6rem; overflow: hidden; font-family: var(--font-mono); font-size: var(--text-xs); margin-bottom: 1.5rem; }
    .terminal-block__bar { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0.75rem; background: rgba(255,255,255,0.025); border-bottom: 1px solid var(--border); }
    .terminal-block__dots { display: flex; gap: 0.3rem; }
    .terminal-block__dots span { width: 8px; height: 8px; border-radius: 50%; background: rgba(255,255,255,0.15); display: block; }
    .terminal-block__title { color: var(--text-dim); font-size: var(--text-2xs); margin-left: auto; margin-right: auto; padding-right: 2.5rem; }
    .terminal-block__body { padding: 0.65rem 0.85rem; display: flex; flex-direction: column; gap: 0.1rem; }
    .t-line { line-height: 1.5; }
    .t-line--spacer { height: 0.35rem; }
    .t-prompt { color: var(--green-600); margin-right: 0.3rem; }
    .t-cmd { color: var(--green-300); }
    .t-out { color: var(--text-dim); padding-left: 1.1rem; }
    .t-comment { color: rgba(255,255,255,0.25); font-style: italic; }

    .cta-card { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.25rem 1.5rem; background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.75rem; }
    .cta-card__content { flex: 1; }
    .cta-card__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--green-50); margin: 0 0 0.25rem; }
    .cta-card__desc { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.55; margin: 0; }
    .cta-card__btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; color: var(--green-50); background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 0.5rem; padding: 0.6rem 1rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: background 0.2s, border-color 0.2s; }
    .cta-card__btn:hover { background: rgba(255,255,255,0.08); border-color: var(--border-hover); }
    @media (max-width: 600px) { .cta-card { flex-direction: column; align-items: flex-start; } }
</style>
