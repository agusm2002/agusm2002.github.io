---
import DocsLayout from "../../../../layouts/DocsLayout.astro";
const vms = [
    { name: "vm-bastion", cpu: "1 OCPU", ram: "6 GB", role: "Unico punto de entrada SSH. Ansible control node. OpenTofu ejecutado desde aca." },
    { name: "vm-k3s", cpu: "3 OCPUs", ram: "18 GB", role: "k3s cluster + todo el stack: Prometheus, Loki, Grafana, n8n, Vault, Jenkins, ArgoCD." },
];
---

<DocsLayout title="Architecture OCI - ITOps Automation Lab" activePage="architecture"
    lang="en"
    prev={{ label: "Checklist de Hardening", href: "/en/aiops-lab/phase-8/hardening-checklist" }}
    next={{ label: "OpenTofu OCI Provider", href: "/en/aiops-lab/phase-9/opentofu-oci" }}
>
    <div class="docs-page">
        <div class="h"><div class="h__top"><div class="h__badge">Phase 9</div><span class="h__time">Oracle Cloud</span></div><h1 class="h__title">Architecture OCI<span class="h__accent"> · Bastion + k3s</span></h1><p class="h__sub">La arquitectura de produccion en Oracle Cloud Free Tier: dos VMs Ampere A1 ARM64, VCN con subnet publica, NSG con least-privilege y servicios gestionados (OCI Vault, Object Storage). Costo total: $0.</p></div>

        <div class="sec">
            <div class="sec__h"><span class="sec__num">01</span><h2 class="sec__h2">Topologia de Red</h2></div>
            <p class="sec__lead">VCN 10.0.0.0/16 con una subnet publica 10.0.1.0/24. Ambas VMs tienen IP publica pero solo el bastion acepta SSH desde internet. La VM k3s solo acepta conexiones desde el bastion.</p>
            <div class="cb"><div class="cb__h"><span class="cb__file">Reglas NSG — acceso SSH</span></div>
                <pre><code>Bastion: SSH (22) ← SOLO desde IP admin (TU_IP/32)
K3s:     SSH (22) ← SOLO desde IP privada del bastion
K3s:     HTTPS (443) ← 0.0.0.0/0 (Grafana demo publica)
K3s:     HTTP (80) ← 0.0.0.0/0 (redirect a HTTPS)
K3s:     k3s API (6443) ← SOLO desde IP privada del bastion</code></pre>
            </div>
        </div>

        <div class="sec">
            <div class="sec__h"><span class="sec__num">02</span><h2 class="sec__h2">Dimensionamiento Free Tier</h2></div>
            <div class="vm-list">
                {vms.map((v) => (
                    <div class="vm"><div class="vm__name">{v.name}</div><div class="vm__specs"><span>{v.cpu}</span><span>{v.ram}</span></div><div class="vm__role">{v.role}</div></div>
                ))}
            </div>
            <div class="info"><div class="info__icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></div><div class="info__text"><b>Total: 4 OCPUs + 24 GB RAM = limite exacto del Free Tier.</b> Boot volumes: 50 GB (bastion) + 100 GB (k3s) = 150 GB (limite: 200 GB). OCI Object Storage: bucket de Loki dentro de los 10 GB/mes gratis. OCI Vault: 20 key versions gratis.</div></div>
        </div>

        <div class="sec sec--cta">
            <div class="cta"><div class="cta__content"><h3 class="cta__title">Siguiente: OpenTofu OCI Provider</h3><p class="cta__desc">Como se provisiona toda esta infraestructura con OpenTofu — el provider de OCI y el workflow de apply.</p></div><a href="/en/aiops-lab/phase-9/opentofu-oci" class="cta__btn"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0118.8-4.3M22 12.5a10 10 0 01-18.8 4.2"/></svg>OCI Provider</a></div>
        </div>
    </div>
</DocsLayout>

<style>
    .docs-page { max-width: 740px; }
    .h { background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.875rem; padding: 1.75rem; margin-bottom: 3rem; }
    .h__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
    .h__badge { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-300); padding: 0.35rem 0.7rem; border-radius: 0.4rem; background: rgba(255,255,255,0.03); border: 1px solid var(--border); }
    .h__time { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-dim); padding: 0.35rem 0.65rem; border-radius: 0.4rem; border: 1px solid var(--border); background: rgba(255,255,255,0.02); }
    .h__title { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--green-50); line-height: 1.15; margin-bottom: 0.5rem; }
    .h__accent { color: var(--green-500); font-weight: 500; }
    .h__sub { font-size: var(--text-md); color: var(--text-muted); line-height: 1.6; max-width: 560px; }
    .sec { margin-bottom: 3rem; }
    .sec--cta { margin-top: 1rem; }
    .sec__h { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; }
    .sec__num { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-600); font-weight: 500; }
    .sec__h2 { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; color: var(--green-50); margin: 0; }
    .sec__lead { font-size: var(--text-base); color: var(--text-muted); line-height: 1.65; margin-bottom: 1.5rem; max-width: 560px; }
    .cb { background: #0a0a0a; border: 1px solid var(--border); border-radius: 0.6rem; overflow: hidden; margin-bottom: 1rem; }
    .cb__h { display: flex; align-items: center; padding: 0.45rem 0.85rem; background: rgba(255,255,255,0.025); border-bottom: 1px solid var(--border); }
    .cb__file { font-family: var(--font-mono); font-size: var(--text-2xs); color: var(--text-dim); }
    .cb pre { margin: 0; padding: 0.85rem; overflow-x: auto; }
    .cb code { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); line-height: 1.55; }
    .vm-list { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
    .vm { background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.75rem; padding: 1rem; }
    .vm__name { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--green-50); margin-bottom: 0.15rem; }
    .vm__specs { display: flex; gap: 0.5rem; margin-bottom: 0.35rem; }
    .vm__specs span { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--green-300); background: rgba(255,255,255,0.04); padding: 0.1rem 0.4rem; border-radius: 0.2rem; border: 1px solid var(--border); }
    .vm__role { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.5; }
    .info { display: flex; gap: 0.65rem; padding: 0.875rem 1rem; background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 0.6rem; font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6; margin-bottom: 1rem; }
    .info__icon { flex-shrink: 0; color: var(--green-400); margin-top: 0.1rem; }
    .info__icon svg { width: 16px; height: 16px; display: block; }
    .info__text b { color: var(--green-50); font-weight: 600; }
    .cta { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.25rem 1.5rem; background: rgba(255,255,255,0.015); border: 1px solid var(--border); border-radius: 0.75rem; }
    .cta__content { flex: 1; }
    .cta__title { font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--green-50); margin: 0 0 0.25rem; }
    .cta__desc { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.55; margin: 0; }
    .cta__btn { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: var(--text-sm); font-weight: 500; color: var(--green-50); background: rgba(255,255,255,0.04); border: 1px solid var(--border); border-radius: 0.5rem; padding: 0.6rem 1rem; text-decoration: none; white-space: nowrap; flex-shrink: 0; transition: background 0.2s, border-color 0.2s; }
    .cta__btn:hover { background: rgba(255,255,255,0.08); border-color: var(--border-hover); }
    @media (max-width: 600px) { .cta { flex-direction: column; align-items: flex-start; } }
</style>
